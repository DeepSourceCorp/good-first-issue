{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run AVA test",
            "preLaunchTask": "npm: cache",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/ava",
            "runtimeArgs": [
                "--serial",
                "--timeout=5m",
                "${fileDirname}/../dist/tests/${fileBasenameNoExtension}.js"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/packages/*/dist/**/*.js"
            ],
            "skipFiles": [
                "<node_internals>/**/*.js"
            ],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Current JS file",
            "program": "${file}",
            "skipFiles": [
                "<node_internals>/**/*.js"
            ],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Release",
            "program": "${workspaceFolder}/dist/release/main.js",
            "args": ["--testMode"],
            "skipFiles": [
                "<node_internals>/**/*.js"
            ],
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "webhint",
            "program": "${workspaceFolder}/packages/hint/dist/src/bin/hint.js",
            "args": [
                "${input:webhintArgs}"
            ],
            "cwd": "${workspaceFolder}/packages/hint/",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/packages/*/dist/**/*.js"
            ],
            "skipFiles": [
                "<node_internals>/**/*.js"
            ],
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "webhintArgs",
            "type": "promptString",
            "description": "Enter the file or URL to analyze with webhint."
        }
    ]
}
